# Copy to .env.local and fill in.
# .env.local is gitignored; never commit real values.

# Or set Google credentials manually (one of the two):
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=<base64 of service account JSON>
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: spreadsheet ID (if set, avoids Drive API lookup by name).
# GOOGLE_SPREADSHEET_ID=1234567890abcdef

# Required for games refresh and Siliva Shield players: NRL API auth header value.
NRL_AUTH=Bearer your-nrl-token

# Optional: salt for user PIN derivation (default: default-salt).
# PIN_SALT=your-secret-salt
